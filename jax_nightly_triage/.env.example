# Copy this file to `.env` (kept out of git) and `source .env` before running.
# All variables are optional; sensible defaults are baked in for the JAX
# nightly Pytest-ROCm case.

# ---- Auth (pick one) ---------------------------------------------------------
# (1) Personal access token  -- recommended, no extra install:
#       https://github.com/settings/tokens
#     Required scopes:
#       - public repos: no scope needed
#       - private repos: 'repo' (classic) OR a fine-grained token with
#                        Actions: read on the target repos
# export GITHUB_TOKEN=ghp_yourtokenhere
#
# (2) OR use the gh CLI:
#       gh auth login
#     Then no token env var is needed.

# ---- Triage targeting --------------------------------------------------------
# Override the default JAX-nightly defaults to point at your own workflow.
# export TRIAGE_REPO="your-org/your-repo"
# export TRIAGE_WORKFLOW_RE="Nightly Tests"
# export TRIAGE_JOB_PREFIX="pytest"
# export TRIAGE_BRANCH="main"

# ---- Diff window -------------------------------------------------------------
# export TRIAGE_WINDOW_DAYS=7
# export TRIAGE_CHRONIC_THRESHOLD=4

# ---- Output paths ------------------------------------------------------------
# export TRIAGE_DB="reports/history.db"
# export TRIAGE_REPORTS_DIR="reports"

# ---- Optional: post markdown report to a tracking issue (run.sh) -------------
# export TRACKING_ISSUE="your-org/your-repo#42"
